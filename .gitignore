# Root .gitignore for PitWall

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn
dist/
build/

# Environment variables
.env
.env.local
.env.*.local
.env.production.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# OS
Thumbs.db
.DS_Store
.vscode/extensions
/src

# Logs
logs/
*.log
lerna-debug.log*

# Testing
coverage/
.nyc_output/
*.lcov

# Packages
*.tgz
*.tar.gz
*.rar

# Lock files (use for frontend/backend as needed)
# Uncomment if enforcing lock file consistency
# package-lock.json
# yarn.lock

# Cache
.cache/
.eslintcache
.prettierignore

# Build outputs
dist/
build/
out/
*.exe
*.dll
*.so
*.dylib
.bin/

# IDE specific
.vs/
.vscode/
*.code-workspace
.IntelliSense/

# Database
*.db
*.sqlite
*.sqlite3

# Secrets
*.pem
*.key
secrets.json
